{
  "patternId": "DQRP1",
  "patternVersion": "1.0",
  "description": "ODRL template for Currentness pattern based on Data Age constraint",
  "context": {
    "odrl:operator": {
      "@type": "@id"
    },
    "@base": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "odrl": "http://www.w3.org/ns/odrl/2/",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dqv": "http://www.w3.org/ns/dqv#",
    "tb": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/tbox#",
    "ab": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/abox#",
    "prov": "http://www.w3.org/ns/prov#",
    "qudt": "http://qudt.org/schema/qudt/"
  },
  "policy": {
    "type": "dqv:QualityPolicy",
    "action": "odrl:distribute"
  },
  "target": {
    "parameter": "attributeName1"
  },
  "assigner": {
    "source": "sourceEntity"
  },
  "assignee": {
    "fixed": "DataProvider"
  },
  "constraint": {
    "leftOperand": {
      "id": "DataAgeMeasurement",
      "type": "dqv:QualityMeasurement"
    },
    "operator": "odrl:lteq",
    "rightOperand": {
      "parameter": "amountOfTime",
      "type": "xsd:integer"
    },
    "unit": {
      "parameter": "timeUnit",
      "mapping": {
        "Minutes": "qudt:MIN",
        "Minute": "qudt:MIN",
        "Hours": "qudt:HR",
        "Hour": "qudt:HR",
        "Days": "qudt:DAY",
        "Day": "qudt:DAY",
        "Seconds": "qudt:SEC",
        "Second": "qudt:SEC"
      }
    }
  },
  "computedOn": {
    "parameter": "attributeName2"
  },
  "dimension": {
    "sourceFromDQR": "qualityDimension.dimension"
  },
  "derivedFrom": {
    "source": "id"
  }
}
