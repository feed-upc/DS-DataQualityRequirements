{
  "patternId": "DQRP3",
  "patternVersion": "1.0",

  "description": "ODRL template for Compliance pattern — values of an attribute must conform to a reference standard",

  "context": {
    "odrl:operator": {
      "@type": "@id"
    },
    "odrl:rightOperand": {
      "@type": "@id"
    },
    "@base": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "odrl": "http://www.w3.org/ns/odrl/2/",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dqv": "http://www.w3.org/ns/dqv#",
    "tb": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/tbox#",
    "ab": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/abox#",
    "prov": "http://www.w3.org/ns/prov#"
  },

  "policy": {
    "type": "dqv:QualityPolicy",
    "action": "odrl:distribute"
  },

  "target": {
    "parameter": "attributeName"
  },

  "assigner": {
    "source": "sourceEntity"
  },

  "assignee": {
    "fixed": "DataProvider"
  },

  "constraint": {
    "leftOperand": {
      "id": "ValidityMeasurement",
      "type": "dqv:QualityMeasurement"
    },

    "operator": "odrl:isIncludedIn",

    "rightOperand": {
      "parameter": "standardName",
      "type": "@id"
    }
  },

  "dimension": {
    "sourceFromDQR": "qualityDimension.dimension"
  },

  "derivedFrom": {
    "source": "id"
  }
}