{
  "@context": {
    "odrl:operator": {
      "@type": "@id"
    },
    "@base": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "odrl": "http://www.w3.org/ns/odrl/2/",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dqv": "http://www.w3.org/ns/dqv#",
    "tb": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/tbox#",
    "ab": "http://www.semanticweb.org/acraf/ontologies/2024/healthmesh/abox#",
    "prov": "http://www.w3.org/ns/prov#",
    "qudt": "http://qudt.org/schema/qudt/"
  },
  "@graph": [
    {
      "@id": "ab:DQR1LSRule",
      "@type": "dqv:QualityPolicy",
      "rdfs:label": "DQR1LS - Timeliness of Live Stocks price data",
      "tb:derivedFrom": "DQR1LS",
      "tb:qualityDimension": "Timeliness",
      "tb:sourceEntity": {
        "@id": "ab:DataSpaceGovernanceAuthority"
      },
      "odrl:permission": [
        {
          "@id": "ab:DQR1LS_Permission",
          "@type": "odrl:Permission",
          "odrl:action": "odrl:distribute",
          "odrl:assigner": {
            "@id": "ab:DataSpaceGovernanceAuthority"
          },
          "odrl:assignee": {
            "@id": "ab:DataProvider"
          },
          "odrl:target": {
            "@id": "ab:price"
          },
          "odrl:constraint": [
            {
              "@id": "ab:DQR1LS_Constraint",
              "@type": "odrl:Constraint",
              "odrl:leftOperand": {
                "@id": "ab:DataAgeMeasurement",
                "@type": "dqv:QualityMeasurement",
                "dqv:computedOn": {
                  "@id": "ab:insertionTime"
                }
              },
              "odrl:operator": "odrl:lteq",
              "odrl:rightOperand": {
                "@value": "30",
                "@type": "xsd:integer"
              },
              "odrl:unit": {
                "@id": "qudt:MIN"
              }
            }
          ]
        }
      ]
    },
    {
      "@id": "ab:DataAgeMeasurement",
      "@type": "dqv:Metric",
      "rdfs:label": "Data Age Measurement (minutes)",
      "dqv:isMeasurementOf": {
        "@id": "ab:CheckFreshness"
      },
      "dqv:computedOn": {
        "@id": "ab:insertionTime"
      }
    },
    {
      "@id": "ab:TimelinessDimension",
      "@type": "dqv:Dimension",
      "rdfs:label": "Timeliness (ISO/IEC 25012)"
    },
    {
      "@id": "ab:price",
      "@type": "odrl:Asset",
      "odrl:partOf": {
        "@id": ""
      }
    }
  ]
}
